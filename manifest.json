{
  "manifest_version": 3,
  "minimum_chrome_version": "111",
  "name": "Equicord Web User Plugins",
  "description": "Equicord Web with custom user plugin support from GitHub or local uploads",
  "author": "Equicord",
  "homepage_url": "https://github.com/Equicord/Equicord",
  "icons": {
    "128": "extension-chrome-src/icon.png"
  },
  "host_permissions": [
    "*://*.discord.com/*",
    "https://raw.githubusercontent.com/*",
    "https://api.github.com/*",
    "https://gist.githubusercontent.com/*"
  ],
  "permissions": [
    "declarativeNetRequest"
  ],
  "content_scripts": [
    {
      "run_at": "document_start",
      "matches": [
        "*://*.discord.com/*"
      ],
      "js": [
        "extension-chrome-src/content.js"
      ],
      "all_frames": true,
      "world": "ISOLATED"
    },
    {
      "run_at": "document_start",
      "matches": [
        "*://*.discord.com/*"
      ],
      "js": [
        "extension-chrome-src/dist/Equicord.js",
        "extension-chrome-src/dist/CustomUserPlugins.js"
      ],
      "all_frames": true,
      "world": "MAIN"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "extension-chrome-src/dist/*",
        "extension-chrome-src/vendor/*",
        "extension-chrome-src/vendor/babel/*"
      ],
      "matches": [
        "*://*.discord.com/*"
      ]
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "modifyResponseHeaders",
        "enabled": true,
        "path": "extension-chrome-src/modifyResponseHeaders.json"
      }
    ]
  },
  "version": "1.14.13.1"
}
